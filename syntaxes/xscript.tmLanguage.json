{
  "name": "XScript",
  "scopeName": "source.xscript",
  "fileTypes": ["xs", "xscript"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#variables" },
    { "include": "#function-call" },
    { "include": "#method-call" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.block.xscript",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.xscript" }
          }
        },
        {
          "name": "comment.line.double-slash.xscript",
          "match": "//.*$"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.xscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.xscript", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.xscript",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.xscript", "match": "\\\\." }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.xscript",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.xscript",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.xscript",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.xscript",
          "match": "\\b(if|else|while|for|foreach|return|break|continue|abort|end|skip|gosub|goto|wait|interrupt|start|stop|do|inc|dec|dim|global|local)\\b"
        },
        {
          "name": "keyword.operator.logical.xscript",
          "match": "\\b(and|or|not|mod|AND|OR|NOT|MOD)\\b"
        },
        {
          "name": "keyword.declaration.xscript",
          "match": "\\b(var|const|function|script|task|define|include)\\b"
        },
        {
          "name": "support.type.xscript",
          "match": "\\b(null|NULL|true|TRUE|false|FALSE)\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "comment": "Built-in object constants",
          "name": "variable.language.xscript",
          "match": "\\b(this|PLAYERSHIP|ThisHomebase|ThisEnvironment|ThisSector|ThisOwner|DOCKEDAT|NULL|TRUE|FALSE|PLAYERSHIP|HOMEBASE|HOMEPLANET|SUPERSECTOR)\\b"
        },
        {
          "comment": "Enum namespaces — RACE.Argon, ShipType.M3, etc.",
          "name": "variable.other.constant.xscript",
          "match": "\\b(RACE|Race|ShipType|StationType|WareClass|ObjClass|Role|Carrier|Fleet|Wing|Sector|Command|AgentCmd|Relation|Flag)\\.[A-Za-z][A-Za-z0-9_.]*"
        },
        {
          "comment": "ALL_CAPS constants",
          "name": "variable.other.constant.xscript",
          "match": "\\b[A-Z][A-Z0-9_]{2,}\\b"
        }
      ]
    },

    "variables": {
      "patterns": [
        {
          "comment": "Dollar-sign variables with optional dot-separated path: $my.variable.name",
          "name": "variable.other.xscript",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_.]*"
        },
        {
          "comment": "Percent argument placeholders: %ARG1%",
          "name": "variable.parameter.xscript",
          "match": "%[A-Z0-9_]+%"
        },
        {
          "comment": "Script arguments: $0, $1 ...",
          "name": "variable.parameter.xscript",
          "match": "\\$[0-9]+"
        }
      ]
    },

    "function-call": {
      "patterns": [
        {
          "comment": "Global function call: name(",
          "name": "entity.name.function.xscript",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        }
      ]
    },

    "method-call": {
      "patterns": [
        {
          "comment": "Method call: $obj->method(",
          "match": "(->)\\s*([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": { "name": "punctuation.accessor.xscript" },
            "2": { "name": "entity.name.function.member.xscript" }
          }
        },
        {
          "comment": "Property access: $obj->property (no parens)",
          "match": "(->)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.accessor.xscript" },
            "2": { "name": "variable.other.property.xscript" }
          }
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.xscript",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.xscript",
          "match": "(=(?!=))"
        },
        {
          "name": "keyword.operator.arithmetic.xscript",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.bitwise.xscript",
          "match": "(&|\\||\\^|~|<<|>>)"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.xscript",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.xscript",
          "match": ","
        },
        {
          "name": "meta.brace.curly.xscript",
          "match": "[{}]"
        },
        {
          "name": "meta.brace.round.xscript",
          "match": "[()]"
        },
        {
          "name": "meta.brace.square.xscript",
          "match": "[\\[\\]]"
        }
      ]
    }
  }
}
